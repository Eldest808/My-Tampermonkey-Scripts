// ==UserScript==
// @name         Smart Copy Cleaner (Bulbagarden & Fandom)
// @namespace    http://tampermonkey.net/
// @version      1.5
// @description  Preserve hyperlinks + remove (Pokémon), (anime), /Legends on specific wikis
// @author       You
// @match        *://*.bulbagarden.net/*
// @match        *://*.fandom.com/*
// @match        *://*.wikipedia.org/*
// @grant        none
// ==/UserScript==

(function () {
    'use strict';

    // FIX: Removed .trim() — trimming individual text nodes kills spaces between
    // a word and an <a> tag (e.g. " " becomes "" and words run together)
    function cleanString(text) {
        return text
            .replace(/\s*\((Pokémon|anime)\)/gi, '')
            .replace(/\/Legends/gi, '')
            .replace(/[^\S\n]{2,}/g, ' ');  // collapse multi-spaces but NOT newlines
    }

    function cleanHTML(container) {
        const walker = document.createTreeWalker(container, NodeFilter.SHOW_TEXT, null, false);
        let node;
        const nodesToProcess = [];
        while (node = walker.nextNode()) {
            nodesToProcess.push(node);
        }
        nodesToProcess.forEach(textNode => {
            textNode.nodeValue = cleanString(textNode.nodeValue);
        });
    }

    function getPlainTextFromHTML(html) {
        const temp = document.createElement('div');
        temp.style.cssText = 'position:absolute;left:-9999px;white-space:pre-wrap';
        temp.innerHTML = html;
        document.body.appendChild(temp);
        const plain = temp.innerText;
        document.body.removeChild(temp);
        // FIX: .trim() belongs HERE only — on the final assembled string, not on text nodes
        return cleanString(plain).trim();
    }

    document.addEventListener("copy", function (e) {
        const selection = window.getSelection();
        if (!selection || selection.rangeCount === 0 || selection.isCollapsed) return;

        const container = document.createElement("div");
        for (let i = 0; i < selection.rangeCount; i++) {
            container.appendChild(selection.getRangeAt(i).cloneContents());
        }

        cleanHTML(container);

        const cleanedHTML = container.innerHTML.trim();
        if (!cleanedHTML) return;

        const cleanedPlain = getPlainTextFromHTML(cleanedHTML);

        e.clipboardData.setData("text/html", cleanedHTML);
        e.clipboardData.setData("text/plain", cleanedPlain);
        e.preventDefault();

        console.log("Copied: Links preserved & text scrubbed.");
    });
})();
